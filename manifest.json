{
  "manifest_version": 3,
  "name": "English Writing Helper",
  "version": "0.1.0",
  "description": "Correct grammar, polish, and restyle selected text using your own OpenAI-compatible LLM.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [],
  "optional_host_permissions": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "vendor/textarea-caret-position.js",
        "vendor/insert-text.js",
        "utils/storage.js",
        "utils/diff.js",
        "utils/selection.js",
        "utils/replace.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "English Writing Helper",
    "default_popup": "popup.html"
  }
}
